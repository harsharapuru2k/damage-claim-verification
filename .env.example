# Copy this file to .env and fill in your AWS credentials.
# NEVER commit .env to git.

# AWS Bedrock credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# Optional: override default models
# BEDROCK_TEXT_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0
# BEDROCK_VISION_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# Optional: delay between API calls (seconds)
# INTER_CALL_DELAY=0.5
